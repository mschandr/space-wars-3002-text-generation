# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=space_wars_3002
DB_CONNECTION=mariadb

# LLM (llama.cpp OpenAI-compatible server)
LLM_BASE_URL=http://localhost:8080
LLM_MODEL=llama3

# LLM parameters — keep temperature low for small local models (design: 0.3-0.5)
LLM_TEMPERATURE=0.4
LLM_TOP_P=0.7
LLM_MAX_TOKENS=500
LLM_TIMEOUT_SECONDS=60

# Job processing
WORKER_COUNT=1
BATCH_SIZE=5
GENERATION_RETRY_MAX=2
ROWS_TO_GENERATE=0

# Generation versioning — increment when prompt templates or model changes
GENERATION_VERSION=1

# HTTP API mode
# When true, Go polls PHP for pending vendors and submits lines via HTTP.
# When false (default), Go reads/writes the database directly.
USE_HTTP_API=false

# Required only when USE_HTTP_API=true
PHP_BASE_URL=http://localhost:8000
PHP_INTERNAL_TOKEN=change-me-to-a-secure-random-string

# Debug/development
DRY_RUN=false
LOG_LEVEL=info
